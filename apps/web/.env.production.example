# =============================================================================
# VOAS AI — Production frontend env vars
# Set these in Vercel → Project Settings → Environment Variables (Production).
# =============================================================================

# --- Supabase Cloud (https://supabase.com/dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://<your-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from Supabase dashboard → Settings → API>

# --- API (Railway / Render / wherever apps/api is deployed) ---
NEXT_PUBLIC_API_URL=https://api.voas.ai

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://voas.ai
NEXT_PUBLIC_ENVIRONMENT=production

# --- Analytics ---
NEXT_PUBLIC_POSTHOG_KEY=<from PostHog project>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=<from Sentry project>

# --- Server-only ---
SUPABASE_SERVICE_ROLE_KEY=<DO NOT EXPOSE — server-only, never NEXT_PUBLIC_*>
RESEND_API_KEY=<from resend.com>
SENTRY_DSN=<same as NEXT_PUBLIC_SENTRY_DSN, used by server-side init>
