# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Analytics (optional in dev) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Sentry (optional in dev) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Cloudflare Turnstile (CAPTCHA on auth). Leave blank to disable the widget
# entirely — auth works normally. When set, also enable CAPTCHA in the Supabase
# dashboard (Auth → Settings → Bot & Abuse Protection) with the matching SECRET key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Server-only ---
RESEND_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
