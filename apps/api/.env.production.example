# =============================================================================
# VOAS AI — Production backend env vars
# Set these in Railway → Service → Variables.
# =============================================================================

ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Supabase Cloud ---
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard → Settings → API>
SUPABASE_JWT_SECRET=<from Supabase dashboard → Settings → API → JWT Settings>
SUPABASE_ANON_KEY=<from Supabase dashboard → Settings → API>

# --- Direct DB (optional — only for one-off psql/maintenance) ---
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-...-pooler.supabase.com:6543/postgres

# --- CORS (must include your prod frontend origin) ---
CORS_ORIGINS=https://voas.ai,https://www.voas.ai

# --- Observability ---
SENTRY_DSN=<from Sentry project>

# --- Email ---
RESEND_API_KEY=<from resend.com>
EMAIL_FROM=no-reply@voas.ai

# --- Rate limiting ---
RATE_LIMIT_GLOBAL_PER_HOUR=10000
RATE_LIMIT_WRITES_PER_MINUTE=200
