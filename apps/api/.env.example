# --- Supabase ---
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=

# --- Direct DB (for migrations / health checks) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- CORS ---
CORS_ORIGINS=http://localhost:3001

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=INFO

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=no-reply@voas.ai

# --- Environment ---
ENVIRONMENT=development

# --- Rate limiting ---
RATE_LIMIT_GLOBAL_PER_HOUR=1000
RATE_LIMIT_WRITES_PER_MINUTE=100

# --- Vapi (V2 Sprint 2+ — voice AI). Leave blank to run without voice. ---
# Get keys from https://dashboard.vapi.ai/api-keys after signing up at vapi.ai.
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_WEBHOOK_SECRET=
# Public URL Vapi will POST webhook events to. In dev:
#   ngrok http 8000   →   then paste the https URL + /v1/webhooks/vapi
VAPI_SERVER_URL=
VAPI_BASE_URL=https://api.vapi.ai

# --- WhatsApp (V2 Sprint 3 — Twilio + OpenAI). Leave blank to run without WhatsApp. ---
# OpenAI generates the WhatsApp AI replies. Required for WhatsApp to actually respond.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Twilio credentials are normally stored per-location in the DB (location_whatsapp_config).
# These globals are only an optional fallback for single-tenant/dev setups.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio's shared WhatsApp sandbox number (used for testing before a production sender).
TWILIO_WHATSAPP_SANDBOX_NUMBER=+14155238886
# Twilio webhook URL (set in the Twilio console, not here):
#   <backend-app>.ondigitalocean.app/v1/webhooks/whatsapp
